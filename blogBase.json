5.png)\n\n![498e7cdb7dc81701e6274b87ae86587e_MD5](https://obsidian-image-bed-1379524953.cos.ap-guangzhou.myqcloud.com/Obsidian/498e7cdb7dc81701e6274b87ae86587e_MD5.webp)\n\n\u8fd9\u4e2a\u4e5f\u662f\u5408\u4e4e\u60c5\u7406\n\n\u6bd5\u7adf\uff0cconsensus\u3001elite\u8fd9\u4e9b\uff0c\u672c\u8d28\u4e0a\u4e5f\u662f\u57fa\u4e8e\u5411\u91cf\u7d22\u5f15\u5339\u914d\u7684AI\u68c0\u7d22\u5de5\u5177\n\n\u81ea\u8eab\u5c31\u643a\u5e26\u8bed\u4e49\u5339\u914d\u3001\u6838\u5b9e\u6587\u732e\u771f\u5b9e\u6027\u7684\u80fd\u529b\n\n\u6240\u4ee5\uff0c\u76f8\u6bd4ChatGPT\u3001Claude\u81ea\u8eab\u7684\u8054\u7f51\u80fd\u529b\u4f1a\u66f4\u5feb\u3001\u66f4\u51c6\u3001\u66f4\u7a33\n\n\u9664\u4e86\u4e0a\u8ff0\u8fd9\u79cd\u65b9\u6cd5\u5916\n\n\u6700\u76f4\u63a5\u7684\u5c31\u662f\u624b\u52a8\u53bb\u627e\u51e0\u7bc7\u548c\u4f60\u4f53\u7cfb\u76f8\u5173\u7684\u9ad8\u8d28\u91cf\u7814\u7a76/\u5b9e\u9a8c\u7c7b\u671f\u520a\n\n\u770b\u4ed6\u4eec\u7684introduction\u501f\u7528\u4e86\u54ea\u4e9b\u6587\u732e\uff0c\u5982\u679c\u4f60\u61d2\u5f97\u624b\u52a8\u6574\u7406\u7684\u8bdd\n\n\u5728\u627e\u51e0\u7bc7\u7136\u540e\u53d1\u7ed9AI\u8ba9\u4ed6\u6839\u636e\u8fd9\u4e9b\u6587\u732e\u5f15\u7528\u7684\u53c2\u8003\u6587\u732e\u8fdb\u884c\u7b5b\u9009\u548c\u6c47\u603b\u5373\u53ef\n\n\u8fd9\u64cd\u4f5c\u65e0\u975e\u5c31\u662f\u6587\u732e\u5f15\u7528\u4e4b\u6587\u732e\u7684\u5f15\u7528\n\n\u76f8\u5f53\u4e8e\u5728\u65f6\u95f4\u4e0a\u5bf9\u540c\u4e00\u4e2a\u89c2\u70b9\u505a\u4e2a\u5d4c\u5957\u5f15\u7528\u7f62\u4e86\n\n\u5f53\u7136\u5982\u679c\u4f60\u8ffd\u6c42\u65f6\u6548\u6027\u548c\u5f15\u7528\u6587\u732e\u8d28\u91cf\u7684\u8bdd\uff0c\u8fd9\u4e2a\u8def\u5f84\u5c31\u4e0d\u592a\u9002\u5408\u4e86\n\n\u76f8\u6bd4\u4e4b\u4e0b\uff0c\u8fd8\u662f\u6211\u6700\u5f00\u59cb\u7684\u90a3\u4e2a\u65b9\u6cd5\u6709\u6548\u5f97\u591a\uff0c\u90a3\u4e2a\u5de5\u5177\u9ed8\u8ba4\u4f1a\u8ffd\u8e2a\u6700\u65b0\u6587\u732e\n\n---\n\n\u53e6\u5916\uff0c\u7ed9\u5927\u5bb6\u5206\u4eab\u4e00\u4e2a\u6211\u81ea\u5df1\u5b9e\u8df5\u4e86\u5f88\u591a\u6b21\u603b\u7ed3\u7684\u7ecf\u9a8c\uff1a\n\n1. \u6307\u5b9a\u6587\u732e\u8d28\u91cf\u8d8a\u9ad8\u8d8a\u597d\u3001\u8d8a\u65b0\u8d8a\u597d\n2. \u9700\u8981\u7ed9\u51fa\u53ef\u8df3\u8f6c\u94fe\u63a5\u6216\u8005\u771f\u5b9eDOI\u53f7\n3. \u4e0d\u786e\u5b9a\u7684\u5185\u5bb9\u4f7f\u7528NA\u6216\u8005none\u5360\u4f4d\n4. \u4ee5\u8868\u683c\u5f62\u5f0f\u8f93\u51fa\u7ed3\u679c\n\n\u5bf9\u4e8e\u7ecf\u9a8c1\uff0c\u662f\u56e0\u4e3a\u6ca1\u6709\u5fc5\u8981\u786c\u6307\u5b9anature\u3001science\u3001Cell\u6216\u8005\u4e13\u4e1a\u9886\u57df\u5185\u9876\u520a\uff0cAI\u4f1a\u6839\u636e\u81ea\u5df1\u77e5\u8bc6\u5e93\u8fdb\u884c\u5224\u65ad\uff0c\u5426\u5219\u4f1a\u56e0\u4e3a\u8fc7\u5206\u8ffd\u6c42\u9ad8\u8d28\u91cf\u9876\u520a\u800c\u5ffd\u7565\u6389\u5176\u4ed6\u76f8\u5173\u6027\u66f4\u9ad8\u7684\u6587\u732e\n\n\u5bf9\u4e8e\u7ecf\u9a8c2\uff0c\u8fd9\u4e2a\u662f\u4fdd\u8bc1\u6587\u732e\u771f\u5b9e\u53ef\u6eaf\u6e90\u7684\u786c\u6027\u8981\u6c42\uff0c\u4e0d\u53ef\u5ffd\u7565\uff0c\u5373\u4fbf\u80fd\u7ed9\u51fa\u8fd8\u662f\u9700\u8981\u4eba\u4e3a\u70b9\u51fb\u94fe\u63a5\u8fdb\u884c\u5ba1\u6838\n\n\u5bf9\u4e8e\u7ecf\u9a8c3\uff0c\u8fd9\u4e2a\u662f\u4e3a\u4e86\u9632\u6b62AI\u634f\u9020\u6570\u636e\uff0c\u5c3d\u7ba1ChatGPT\u5bf9\u4e8e\u4e8b\u5b9e\u771f\u5b9e\u6027\u5f88\u770b\u91cd\uff0c\u4f46\u8fd8\u662f\u8981\u4ee5\u9632\u4e07\u4e00\n\n\u5bf9\u4e8e\u7ecf\u9a8c4\uff0c\u8fd9\u4e2a\u662f\u6211\u7684\u4e60\u60ef\uff0c\u8868\u683c\u603b\u6bd4\u5217\u8868\u76f4\u89c2\uff0c\u4e5f\u662f\u4e3a\u4e86\u8ba9AI\u5e26\u7740\u6846\u67b6\u601d\u7ef4\u6574\u7406\u641c\u96c6\u5230\u7684\u8d44\u6599\n\n---\n\n\u6700\u540e\uff0c\u518d\u7ed9\u5927\u5bb6\u5b89\u5229\u4e00\u4e2a\u63d0\u793a\u8bcd\u798f\u5229\uff08\u81ea\u5df1\u51dd\u7ec3\u5b9e\u8df5\u51e0\u4e2a\u6708\u6574\u7406\u800c\u6210\uff09\uff1a\n\n\u6587\u732e\u89e3\u8bfb\uff1a\n\n```\n\u8bf7\u4f60\u9010\u7bc7\u901a\u8bfb\u6211\u4e0a\u4f20\u7684\u6587\u732e\uff0c\u4e0d\u505a\u8bc4\u4ef7\u6027\u53d1\u6325\uff1b\u6bcf\u7bc7\u63d0\u53d6\uff1a\u7814\u7a7